app_name: {{ .ProjectName }}
env: dev
http:
  host: 0.0.0.0
  port: 8080

database:
  enabled: false
  driver: postgres
  dsn: "postgres://user:pass@localhost:5432/db?sslmode=disable"

redis:
  enabled: false
  addr: "127.0.0.1:6379"

mq:
  enabled: false
  type: nsq
  addr: "127.0.0.1:4150"

grpc:
  enabled: false
  addr: ":9090"
  timeout_sec: 5
  max_retries: 2

governance:
  breaker:
    enabled: false
  limiter:
    enabled: false
    qps: 100
  retry:
    enabled: false

observability:
  trace:
    enabled: true
  metrics:
    enabled: true
    path: /metrics
  health:
    enabled: true
    path: /healthz

enterprise:
  jwt:
    enabled: false
  casbin:
    enabled: false
  idgen:
    mode: uuid
