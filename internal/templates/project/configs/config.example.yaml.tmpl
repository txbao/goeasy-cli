# 应用基础信息（示例配置，可复制为 config.dev.yaml 并用 -f 指定）
app_name: {{ .ProjectName }}
env: dev

http:
  host: 0.0.0.0
  port: 8080

database:
  enabled: true
  orm: sqlx
  driver: postgres
  dsn: "postgres://user:pass@localhost:5432/{{ .ProjectName }}?sslmode=disable"
  max_open: 10
  max_idle: 5

redis:
  enabled: true
  addr: "127.0.0.1:6379"
  password: "your-redis-password"
  db: 0

mq:
  enabled: false
  type: nsq
  addr: "127.0.0.1:4150"

grpc:
  enabled: false
  addr: ":9090"
  timeout_sec: 5
  max_retries: 2

governance:
  breaker:
    enabled: false
  limiter:
    enabled: false
    qps: 100
    burst: 200
  retry:
    enabled: false
    max_retries: 3
    backoff_ms: 100

observability:
  trace:
    enabled: true
  metrics:
    enabled: true
    path: /metrics
  audit:
    enabled: false
  health:
    enabled: true
    path: /healthz

enterprise:
  jwt:
    enabled: false
    secret: "change-me"
    issuer: {{ .ProjectName }}
    expire_min: 60
  casbin:
    enabled: false
  idgen:
    mode: uuid
