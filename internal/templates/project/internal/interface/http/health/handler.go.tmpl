package health

import (
	"net/http"

	"github.com/gin-gonic/gin"
	zresp "{{ .GoEasyModule }}/response"

	apphealth "{{ .ModuleName }}/internal/app/health"
)

// Handler HTTP 适配：调用 Application Query/Command。
type Handler struct {
	app *apphealth.Application
}

func NewHandler(app *apphealth.Application) *Handler {
	return &Handler{app: app}
}

func (h *Handler) Check(c *gin.Context) {
	status, err := h.app.Queries().Check(c.Request.Context(), "{{ .ProjectName }}")
	if err != nil {
		zresp.FailInternal(c, err)
		return
	}
	zresp.Success(c, CheckResponse{
		OK:      status.OK,
		Message: status.Message,
	})
}
