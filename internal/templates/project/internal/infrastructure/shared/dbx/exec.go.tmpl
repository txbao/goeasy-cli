package dbx

import (
	"context"
	"database/sql"
	"errors"
	"time"

	zsqllog "{{ .GoEasyModule }}/sqllog"
)

// TableName 组合配置 table_prefix 与模块表名（prefix 如 ge_，module 如 sys_roles）。
func TableName(prefix, module string) string {
	if prefix == "" {
		return module
	}
	return prefix + module
}

// GetContext 使用 sqlx 执行 goqu 生成的查询。
func GetContext(ctx context.Context, db *DB, dest any, query string, args ...any) error {
	start := time.Now()
	err := db.SQLX.GetContext(ctx, dest, query, args...)
	zsqllog.LogDuration(ctx, "query", query, time.Since(start), args...)
	return err
}

// SelectContext 列表查询。
func SelectContext(ctx context.Context, db *DB, dest any, query string, args ...any) error {
	start := time.Now()
	err := db.SQLX.SelectContext(ctx, dest, query, args...)
	zsqllog.LogDuration(ctx, "select", query, time.Since(start), args...)
	return err
}

// ExecContext 使用 sqlx 执行 goqu 生成的写操作。
func ExecContext(ctx context.Context, db *DB, query string, args ...any) (sql.Result, error) {
	start := time.Now()
	res, err := db.SQLX.ExecContext(ctx, query, args...)
	zsqllog.LogDuration(ctx, "exec", query, time.Since(start), args...)
	return res, err
}

// IsNotFound 判断是否为无行错误。
func IsNotFound(err error) bool {
	return errors.Is(err, sql.ErrNoRows)
}
