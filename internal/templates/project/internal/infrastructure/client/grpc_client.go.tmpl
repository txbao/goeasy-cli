package client

import (
	"context"
	"fmt"

	goeasyapp "{{ .GoEasyModule }}/app"
)

// ExampleDial 低级 API：单次 dial（联调/测试用）。
//
// 业务代码请使用 infrastructure/rpc Gateway + HTTPInfra.RPC 长连接，见 internal/infrastructure/rpc/README.md。
//
// 联调无需本地 .proto：goeasy-cli grpc resolve/call/list --service <app_name>
func ExampleDial(application *goeasyapp.App, serviceName string) error {
	ctx := context.Background()
	cli, err := application.NewGRPCClientForService(ctx, serviceName)
	if err != nil {
		return err
	}
	defer cli.Close()
	fmt.Printf("grpc connected to service %q target %s\n", serviceName, cli.Target())
	return nil
}

// ExampleDialViaRegistry 推荐：通过 Registry 长连接（与 bootstrap Gateway 相同机制）。
func ExampleDialViaRegistry(infra goeasyapp.HTTPInfra, serviceName string) error {
	if infra.RPC == nil {
		return fmt.Errorf("HTTPInfra.RPC is nil")
	}
	cli, err := infra.RPC.Client(context.Background(), serviceName)
	if err != nil {
		return err
	}
	fmt.Printf("grpc registry client service %q target %s\n", serviceName, cli.Target())
	return nil
}
