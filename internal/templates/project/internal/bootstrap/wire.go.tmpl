package bootstrap

import (
	"github.com/gin-gonic/gin"

	goeasyapp "{{ .GoEasyModule }}/app"
)

// RegisterRoutes 在 bootstrap 完成依赖装配。
// CORS / Trace / 限流 由 goeasy httpx 引擎按 config 自动挂载；鉴权见 internal/interface/http/middleware。
func RegisterRoutes(engine *gin.Engine, infra goeasyapp.HTTPInfra) error {
	registerHealth(engine)
	return registerAllModules(engine, infra)
}
