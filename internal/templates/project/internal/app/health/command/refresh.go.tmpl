package command

import (
	"context"

	domain "{{ .ModuleName }}/internal/domain/health"
)

// Handler 写侧处理器（CQRS Command）。
type Handler struct {
	repo      domain.Repository
	domainSvc *domain.DomainService
}

func NewHandler(repo domain.Repository, domainSvc *domain.DomainService) *Handler {
	return &Handler{repo: repo, domainSvc: domainSvc}
}

// RefreshCommand 刷新健康状态命令。
type RefreshCommand struct {
	ServiceName string
	Healthy     bool
	Message     string
}

// Refresh 执行写操作：Load → 聚合行为 → Save。
func (h *Handler) Refresh(ctx context.Context, cmd RefreshCommand) (domain.Status, error) {
	agg, err := h.repo.Load(ctx, cmd.ServiceName)
	if err != nil {
		return domain.Status{}, err
	}
	if err := agg.Refresh(cmd.Healthy, cmd.Message); err != nil {
		return domain.Status{}, err
	}
	if err := h.repo.Save(ctx, agg); err != nil {
		return domain.Status{}, err
	}
	_ = domain.NewStatusChanged(cmd.ServiceName, agg.Status())
	return h.domainSvc.Evaluate(ctx, agg)
}
