package command

import "context"

type UpdateCommand struct {
	ID string
}

func (h *Handler) Update(ctx context.Context, cmd UpdateCommand) error {
	agg, err := h.repo.FindByID(ctx, cmd.ID)
	if err != nil {
		return err
	}
	if err := agg.Enable(); err != nil {
		return err
	}
	return h.repo.Save(ctx, agg)
}
