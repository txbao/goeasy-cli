package {{ .HTTPPackage }}

import (
	"net/http"

	"github.com/gin-gonic/gin"

	app "{{ .ModuleName }}/internal/app/{{ .Domain }}/{{ .Resource }}"
	"{{ .ModuleName }}/internal/app/{{ .Domain }}/{{ .Resource }}/command"
	zresp "{{ .GoEasyModule }}/response"
	zvalid "{{ .GoEasyModule }}/validator"
)

type Handler struct {
	app *app.Application
}

func NewHandler(application *app.Application) *Handler {
	return &Handler{app: application}
}

func (h *Handler) Get(c *gin.Context) {
	id := c.Param("id")
	agg, err := h.app.Queries().Get(c.Request.Context(), id)
	if err != nil {
		zresp.Fail(c, http.StatusInternalServerError, err.Error())
		return
	}
	zresp.Success(c, ToResponse(agg))
}

{{- if .ClientFullCRUD }}
func (h *Handler) Create(c *gin.Context) {
	var cmd command.CreateCommand
	if err := c.ShouldBindJSON(&cmd); err != nil {
		zresp.Fail(c, http.StatusBadRequest, err.Error())
		return
	}
	if err := zvalid.Validate(&cmd); err != nil {
		zresp.Fail(c, http.StatusBadRequest, zvalid.Format(err))
		return
	}
	id, err := h.app.Commands().Create(c.Request.Context(), cmd)
	if err != nil {
		zresp.Fail(c, http.StatusInternalServerError, err.Error())
		return
	}
	zresp.Success(c, gin.H{"id": id})
}
{{- end }}
