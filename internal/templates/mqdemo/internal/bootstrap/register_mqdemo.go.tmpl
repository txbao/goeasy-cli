package bootstrap

import (
	"github.com/gin-gonic/gin"

	goeasyapp "{{ .GoEasyModule }}/app"

	appmqdemo "{{ .ModuleName }}/internal/app/mqdemo"
	domain "{{ .ModuleName }}/internal/domain/mqdemo"
	mqinfra "{{ .ModuleName }}/internal/infrastructure/mq"
	repo "{{ .ModuleName }}/internal/infrastructure/persistence/repository/mqdemo"
	mqdemohttp "{{ .ModuleName }}/internal/interface/http/mqdemo"
)

// RegisterMQDemo 装配并注册 mqdemo HTTP 路由。
func RegisterMQDemo(engine *gin.Engine, infra goeasyapp.HTTPInfra) error {
	repository := repo.NewMemoryRepository()
	publisher := mqinfra.NewPublisher(infra.MQ, "mqdemo")
	application := appmqdemo.NewApplication(repository, publisher)
	_ = domain.DefaultTopic
	h := mqdemohttp.NewHandler(application)
	api := engine.Group("/api/v1")
	mqdemohttp.RegisterRoutes(api, h)
	return nil
}
