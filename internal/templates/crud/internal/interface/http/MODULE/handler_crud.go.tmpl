package {{ .ModuleSnake }}

import (
	"net/http"

	"github.com/gin-gonic/gin"

	"{{ .ModuleName }}/internal/app/{{ .ModuleSnake }}/command"
	zresp "github.com/txbao/goeasy/response"
)

func (h *Handler) List(c *gin.Context) {
	ids, err := h.app.Queries().List(c.Request.Context())
	if err != nil {
		zresp.Fail(c, http.StatusInternalServerError, err.Error())
		return
	}
	zresp.Success(c, gin.H{"items": ids})
}

func (h *Handler) Update(c *gin.Context) {
	id := c.Param("id")
	if err := h.app.Commands().Update(c.Request.Context(), command.UpdateCommand{ID: id}); err != nil {
		zresp.Fail(c, http.StatusInternalServerError, err.Error())
		return
	}
	zresp.Success(c, gin.H{"updated": id})
}

func (h *Handler) Delete(c *gin.Context) {
	id := c.Param("id")
	if err := h.app.Commands().Delete(c.Request.Context(), id); err != nil {
		zresp.Fail(c, http.StatusInternalServerError, err.Error())
		return
	}
	zresp.Success(c, gin.H{"deleted": id})
}
